<MainView>:
    address: address
    results: results
    BoxLayout:
        orientation: "vertical"
        padding: [16, 16, 16, 16]
        spacing: 16
        Label:
            id: results
            size_hint: 1.0, 0.60
            text: "HELLO"
        TextInput:
            id: address
            size_hint: 1.0, None
            height: 30
            halign: "center"
            valign: "center"
            hint_text: "192.168.1.XX"
        Button:
            size_hint: 1.0, 0.1
            text: "GATHER"
            on_release: root.gather()
            disabled: root.loading
        Button:
            size_hint: 1.0, 0.1
            text: "UNPACK"
            on_release: root.unpack()
            disabled: root.loading
        Button:
            size_hint: 1.0, 0.1
            text: "UPDATE"
            on_release: root.update()
            disabled: root.loading